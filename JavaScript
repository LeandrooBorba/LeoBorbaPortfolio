document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Recurso da Página Inicial (Saudação Dinâmica)
    const botao = document.getElementById('btn-saudacao');
    const mensagem = document.getElementById('mensagem-saudacao');

    if (botao && mensagem) {
        botao.addEventListener('click', () => {
            const horaAtual = new Date().getHours();
            let saudacao = '';

            if (horaAtual >= 5 && horaAtual < 12) {
                saudacao = '☀️ Bom dia! Seja bem-vindo ao meu espaço.';
            } else if (horaAtual >= 12 && horaAtual < 18) {
                saudacao = '🌤️ Boa tarde! Obrigado pela visita.';
            } else {
                saudacao = '🌙 Boa noite! Sinta-se à vontade para explorar.';
            }

            mensagem.textContent = saudacao;
            mensagem.classList.toggle('hidden');
        });
    }

    // 2. Recurso da Página de Contato (Simulação de envio)
    const formulario = document.getElementById('form-contato');
    const feedback = document.getElementById('feedback-form');

    if (formulario && feedback) {
        formulario.addEventListener('submit', (evento) => {
            evento.preventDefault(); 
            
            feedback.textContent = '✅ Mensagem enviada com sucesso!';
            feedback.classList.remove('hidden');
            
            formulario.reset();
        });
    }
});
